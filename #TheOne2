#TheOne2. Даны вещественные числа x и y. Определить, принадлежит ли точка с координатами (x, y)
# заштрихованной части плоскости, обозначенной на рис. 2. Считать, что точки на границе также принадлежат
# области. В качестве результата вывести логическое значение.

import math
x = float(input("Введите координату x: "))
y = float(input("Введите координату y: "))

otv = (x**2 + y**2 <= 4) and (y <= x / 2)

print(otv)
