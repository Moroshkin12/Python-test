#TheOne20. Написать программу, которая по вводимому номеру единицы измерения
# (1 — мегабайт, 2 — килобайт, 3 — байт, 4 — бит, 5 — машинное слово) и объёму памяти V выдавала
# бы соответствующее значение объёма памяти в байтах. Считать, что машинное слово составляет 2 байта.
# Использовать оператор switch.

V = int(input("Введите объем памяти V: "))
k = int(input("Введите номер единицы измерения:\n 1 - мегабайты\n 2 - килобайты\n 3 - байты\n 4 - биты\n 5 - Машинное слово\n"))
match k:
    case 1:
        bites = V * (2**10) * (2**10)
        print(V," Мегабайтов = ",bites," Байтов")
    case 2:
        bites = V * (2**10)
        print(V," килобайтов = ",bites," Байтов")
    case 3:
        bites =  V
        print(V," байтов = ",bites," Байтов")
    case 4:
        bites = V / (2**3)
        print(V," битов = ",bites," Байтов")
    case 5:
        bites = V * 2
        print(V," машинных слов = ",bites," Байтов")
    case _:
        print("Номер введен неверно. Введите число от 1 до 5 !!!")
